# Copier vers .env.local sur le serveur (ne pas commiter .env.local).
# Format strict : CLE=valeur (signe égal, pas de tiret entre clé et valeur).

MONGODB_URI=mongodb://mongo:27017/education
NEXTAUTH_URL=https://itkane.net
NEXTAUTH_SECRET=
SUPER_ADMIN_EMAIL=admin@itkane.net
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRSTNAME=Super
SUPER_ADMIN_LASTNAME=Admin

# Upload fichiers : STORAGE_SECRET recommandé ; sinon NEXTAUTH_SECRET suffit (repli dans le code)
STORAGE_SECRET=
STORAGE_ROOT=/srv/itekane-storage
STORAGE_PUBLIC_URL=https://itkane.net/media
MAX_UPLOAD_SIZE=104857600

BANKILY_MERCHANT_USERNAME=
BANKILY_MERCHANT_PASSWORD=
